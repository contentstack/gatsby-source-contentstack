{
  "name": "gatsby-source-contentstack",
  "version": "5.4.5",
  "description": "Gatsby source plugin for building websites using Contentstack as a data source",
  "scripts": {
    "prepublish": "npm run build",
    "build": "babel src --out-dir .",
    "watch": "babel -w src --out-dir .",
    "test": "jest —-colors",
    "test:watch": "jest —-colors --watch"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "main": "gatsby-node.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/contentstack/gatsby-source-contentstack"
  },
  "keywords": [
    "gatsby",
    "gatsby-plugin",
    "gatsby-source-plugin"
  ],
  "author": {
    "name": "Contentstack",
    "url": "https://www.contentstack.com"
  },
  "license": "MIT",
  "dependencies": {
    "@contentstack/utils": "^1.9.1",
    "contentstack": "^3.27.0",
    "gatsby-core-utils": "^3.25.0",
    "gatsby-source-filesystem": "^5.16.0",
    "lodash.clonedeep": "^4.5.0",
    "lodash.isempty": "^4.4.0",
    "node-fetch": "^2.7.0",
    "progress": "^2.0.3",
    "query-string": "^7.1.3"
  },
  "devDependencies": {
    "@babel/cli": "^7.29.7",
    "@babel/core": "^7.29.7",
    "@babel/plugin-proposal-object-rest-spread": "^7.20.7",
    "@babel/plugin-transform-async-to-generator": "^7.29.7",
    "@babel/plugin-transform-runtime": "^7.29.7",
    "@babel/preset-env": "^7.29.7",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^11.0.7",
    "@types/jest": "^29.5.14",
    "@babel/eslint-parser": "^7.29.7",
    "eslint": "^8.57.1",
    "eslint-config-airbnb": "^19.0.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^4.6.2",
    "husky": "^4.3.8",
    "jest": "^29.7.0",
    "prettier": "^3.8.4",
    "semantic-release": "^24.2.9"
  },
  "peerDependencies": {
    "gatsby": "5.16.1",
    "gatsby-plugin-image": "^3.0.0-next"
  },
  "husky": {
    "hooks": {
      "commit-msg": "npx --no-install commitlint --edit ${1}"
    }
  },
  "overrides": {
    "@pnpm/npm-conf": "^3.0.2",
    "axios": "1.17.0",
    "cookie": "0.7.2",
    "file-type": "21.3.4",
    "follow-redirects": "1.16.0",
    "glob": "^9.3.5",
    "immutable": "4.3.8",
    "lodash": "4.18.1",
    "path-to-regexp": "0.1.13",
    "postcss": "8.5.15",
    "serialize-javascript": "7.0.5",
    "tmp": "0.2.7",
    "uuid": "14.0.0",
    "webpack": "5.107.2"
  },
  "resolutions": {
    "@semantic-release/commit-analyzer/semantic-release": "^17.0.0"
  }
}